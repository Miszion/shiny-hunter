{
  "name": "shiny-hunter",
  "version": "1.0.0",
  "description": "Pokemon shiny hunting automation with visual detection",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "hunt:starter": "HUNT_TYPE=starter HUNT_MODE=switch-rng node dist/index.js",
    "hunt:wild": "HUNT_TYPE=wild node dist/index.js",
    "hunt:static": "HUNT_TYPE=static node dist/index.js",
    "hunt:fossil": "HUNT_TYPE=static node dist/index.js",
    "logs": "tail -f logs/combined.log logs/lua-bridge.log",
    "logs:error": "tail -f logs/error.log",
    "logs:lua": "tail -f logs/lua-bridge.log",
    "test": "jest",
    "test:rng": "jest rng.test",
    "test:switch": "jest switch-rng.test",
    "test:pid": "jest pid-identification.test",
    "logs:all": "tail -f logs/combined.log logs/error.log logs/lua-bridge.log",
    "install-hooks": "sh scripts/install-hooks.sh",
    "postinstall": "if [ -f scripts/install-hooks.sh ]; then sh scripts/install-hooks.sh; fi"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "serialport": "^13.0.0",
    "sharp": "^0.33.0",
    "tesseract.js": "^7.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
